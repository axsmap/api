{
  "name": "api",
  "version": "2.0.0",
  "description": "AXS Map API endpoints",
  "main": "src/index.js",
  "repository": "git@github.com:axsmap/api.git",
  "author": "Gustavo <andrescabral.c@gmail.com>",
  "private": true,
  "scripts": {
    "cmt": "git-cz",
    "deploy": "now && now alias",
    "serve": "cross-env NODE_ENV=development gulp",
    "start": "node src/index.js",
    "sync:badges": "node src/scripts/sync-badges.js",
    "sync:badges:dry-run": "node src/scripts/sync-badges.js --dry-run",
    "reconcile:badges": "node src/scripts/reconcile-earned-badges.js",
    "backfill:badge-countries": "node src/scripts/backfill-venue-country-codes.js",
    "provision:salesforce-badges": "node src/scripts/provision-salesforce-badges.js",
    "seed:badges": "node src/scripts/seed-badges-and-contact-mappings.js",
    "publish:badge-assets": "node src/scripts/publish-badge-asset-urls.js",
    "verify:badge-assets": "node src/scripts/verify-badge-assets.js",
    "reconcile:salesforce-fundraising": "node src/scripts/reconcile-salesforce-fundraising.js",
    "reconcile:salesforce-fundraising:apply": "node src/scripts/reconcile-salesforce-fundraising.js --apply --confirm-production",
    "backfill:salesforce-leaderboard": "node src/scripts/backfill-leaderboard-salesforce.js",
    "backfill:salesforce-leaderboard:apply": "node src/scripts/backfill-leaderboard-salesforce.js --apply --confirm-production",
    "reconcile:salesforce-campaigns": "node src/scripts/reconcile-mapathon-campaigns.js",
    "reconcile:salesforce-campaigns:apply": "node src/scripts/reconcile-mapathon-campaigns.js --apply --confirm-production",
    "inspect:salesforce-principal": "node src/scripts/inspect-salesforce-principal.js",
    "provision:salesforce-badges:cli": "node src/scripts/run-with-salesforce-cli-auth.js src/scripts/provision-salesforce-badges.js",
    "deploy:salesforce-badges:cli": "node src/scripts/deploy-salesforce-badge-metadata.js",
    "sync:badges:cli": "node src/scripts/sync-badges-salesforce-cli.js"
  },
  "devDependencies": {
    "commitizen": "2.10.1",
    "cross-env": "5.0.5",
    "cz-conventional-changelog": "2.1.0",
    "eslint": "4.19.1",
    "eslint-config-semistandard": "12.0.1",
    "eslint-config-standard": "11.0.0",
    "eslint-plugin-import": "2.10.0",
    "eslint-plugin-node": "6.0.1",
    "eslint-plugin-promise": "3.7.0",
    "eslint-plugin-standard": "3.1.0",
    "gulp": "3.9.1",
    "gulp-eslint": "4.0.0",
    "gulp-nodemon": "2.2.1",
    "husky": "1.0.0-rc.13",
    "lint-staged": "7.2.2",
    "prettier": "1.14.2"
  },
  "dependencies": {
    "aws-sdk": "2.94.0",
    "axios": "0.33.0",
    "bcrypt-nodejs": "0.0.3",
    "body-parser": "1.17.2",
    "cors": "2.8.4",
    "dotenv": "4.0.0",
    "express": "4.15.3",
    "form-data": "2.3.2",
    "freemail": "1.5.0",
    "google-auth-library": "9.15.1",
    "helmet": "3.8.1",
    "ip": "1.1.5",
    "jimp": "0.2.28",
    "jsonwebtoken": "7.4.1",
    "lodash": "4.17.4",
    "moment": "2.18.1",
    "moment-timezone": "0.5.21",
    "mongodb": "^6.21.0",
    "mongodb-uri": "0.9.7",
    "mongoose": "5.13.23",
    "morgan": "1.8.2",
    "multer": "1.3.0",
    "nodemailer": "4.0.1",
    "now": "11.4.6",
    "randomstring": "1.1.5",
    "raven": "2.6.0",
    "socket.io": "^4.8.3",
    "speakingurl": "14.0.0",
    "validator": "9.4.1"
  },
  "lint-staged": {
    "src/**/*.{js}": [
      "eslint --fix",
      "git add"
    ],
    "src/**/*.{js,json}": [
      "prettier --single-quote --trailing-comma none --tab-width=2 --write",
      "git add"
    ]
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-conventional-changelog"
    }
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  }
}
